# Where to run the tests against. Defaults to localhost:3000.
BASE_URL=https://measure.canadasroofer.com

# Admin credentials for tests that exercise the admin dashboard.
# Use a dedicated test admin account, NOT your production admin.
ADMIN_EMAIL=test-admin@canadasroofer.com
ADMIN_PASSWORD=set-a-strong-test-only-password

# Test customer credentials (for tests that need a logged-in customer).
CUSTOMER_EMAIL=test-customer@canadasroofer.com
CUSTOMER_PASSWORD=set-a-strong-test-only-password

# A real address with known LiDAR coverage. The 624 Merrill regression
# anchor from estimate-engine.ts is a safe bet.
TEST_ADDRESS=624 Merrill Ave, Bedford, OH

# When true, Playwright launches `npm run dev` before tests.
# Leave unset for staging/production tests.
START_DEV_SERVER=false
