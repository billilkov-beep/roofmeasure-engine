# ============================================================================
# roofmeasure-engine — .env.example
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit a file that
# contains real values. Placeholder words like `replace_me` should be obvious
# in code review.
#
# All variables here are for the ENGINE only. The portal has its own
# .env.example in the `roofmeasure-portal` repo.
# ============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Shared secret between portal and engine. Portal sends this in the
# X-API-Key header; engine middleware rejects requests without it.
# Generate with: openssl rand -hex 32
ENGINE_API_KEY=replace_me_with_random_64_hex_chars

# Google Cloud API key. Must have these APIs enabled:
#   - Solar API
#   - Static Maps API
#   - Street View Static API
# Rotate at least quarterly. Restrict by IP (your VPS IP) in Google Cloud Console.
GOOGLE_API_KEY=replace_me_with_google_cloud_api_key

# -----------------------------------------------------------------------------
# OPTIONAL — provider configuration
# -----------------------------------------------------------------------------

# Separate Solar API key if you want per-API billing separation in Google
# Cloud. If empty, GOOGLE_API_KEY is used for Solar too.
GOOGLE_SOLAR_API_KEY=

# Microsoft Planetary Computer subscription key. Anonymous works for low
# volume; subscribed gives higher rate limits.
PC_SUBSCRIPTION_KEY=

# USGS 3DEP doesn't require a key.
# NRCan HRDEM doesn't require a key.
# Overpass doesn't require a key (but rate-limited; we rotate mirrors).

# -----------------------------------------------------------------------------
# OPTIONAL — service tuning
# -----------------------------------------------------------------------------

# FastAPI bind address. Production: 127.0.0.1:8080 behind nginx.
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/roofmeasure/engine.log

# Usage SQLite path
USAGE_DB_PATH=/var/lib/roofmeasure/usage.db

# Cache directories (created on first use)
CACHE_DIR_LIDAR=/var/cache/roofmeasure/lidar
CACHE_DIR_MS_BUILDINGS=/var/cache/roofmeasure/ms-buildings
CACHE_DIR_OSM=/var/cache/roofmeasure/osm

# Default strategy (one of: auto, lidar-first, solar-first, cache-only)
# Portal can override per request with the "strategy" field.
DEFAULT_STRATEGY=auto

# Per-provider request timeouts (seconds)
TIMEOUT_OSMNX=15
TIMEOUT_OVERPASS=30
TIMEOUT_LIDAR_DOWNLOAD=60
TIMEOUT_NRCAN=30
TIMEOUT_SOLAR=20
TIMEOUT_MS_GLOBAL_ML=45

# -----------------------------------------------------------------------------
# OPTIONAL — admin auth (separate from ENGINE_API_KEY)
# -----------------------------------------------------------------------------

# Token required for /admin/* endpoints (in addition to the engine API key).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=replace_me_with_random_64_hex_chars

# -----------------------------------------------------------------------------
# OPTIONAL — error reporting
# -----------------------------------------------------------------------------

SENTRY_DSN=

# -----------------------------------------------------------------------------
# Hostinger deploy — these go in GitHub repository secrets, NEVER here.
# Listed for documentation only.
# -----------------------------------------------------------------------------
# HOSTINGER_VPS_HOST=
# HOSTINGER_VPS_USER=root
# HOSTINGER_VPS_SSH_KEY=    (private key contents; base64-encode in CI)
