# /etc/roofmeasure-engine.env
#
# Copy to /etc/roofmeasure-engine.env, chmod 600, chown root:roofmeasure.
# Loaded by the systemd unit at start.

# REQUIRED if the engine is exposed publicly. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Must match an entry in /etc/nginx/lidar_api_keys.map.
ROOFMEASURE_API_KEY=replace_this_with_real_token_urlsafe_48

# Engine strategy: auto | lidar_only | solar_only | solar_first
ROOFMEASURE_STRATEGY=auto

# Where to cache LAZ tiles between requests (persistent, can be large)
ROOFMEASURE_CACHE_DIR=/var/cache/roofmeasure

# Optional: improves geocoding accuracy
GOOGLE_GEOCODING_API_KEY=

# Required if you use the Solar API engine (strategy=solar_*, or as auto fallback)
# Get from console.cloud.google.com -> APIs & Services -> Solar API
GOOGLE_SOLAR_API_KEY=

# Required imagery quality for Solar API. HIGH gives best accuracy but lowest
# coverage. MEDIUM is a sensible default for production.
GOOGLE_SOLAR_REQUIRED_QUALITY=HIGH

# Optional: OpenTopography key for the easy LiDAR path. Free at
# opentopography.org/developers.
OPENTOPO_API_KEY=

# Local mirror of Microsoft Building Footprints (US + Canada) as fallback
# when OSM lacks a building polygon. Optional.
MSBF_LOCAL_MIRROR=
